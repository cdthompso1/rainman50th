<div id="easter-root" class="easter-hidden" role="dialog" aria-hidden="true">
  <canvas id="confetti-canvas"></canvas>
  <div class="easter-backdrop"></div>
  <div class="easter-modal">
    <h3>🎉 Surprise!</h3>
    <p>Happy 50th, Rainman — from your friends.</p>
    <button id="easter-close">Close</button>
  </div>
</div>

<style>
  #easter-root{position:fixed;inset:0;display:none;align-items:center;justify-content:center;z-index:9999}
  #easter-root.easter-show{display:flex}
  #confetti-canvas{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:3}
  .easter-backdrop{position:absolute;inset:0;background:rgba(0,0,0,0.6);z-index:2}
  .easter-modal{position:relative;background:#0b0b0b;border:1px solid #2bff9e;padding:1.25rem 1.5rem;border-radius:8px;color:var(--text);max-width:420px;text-align:center;box-shadow:0 10px 30px rgba(0,0,0,0.6);z-index:4}
  .easter-modal h3{margin:0 0 0.5rem;font-size:1.25rem}
  #easter-close{margin-top:0.75rem;padding:0.5rem 0.85rem;border-radius:6px;border:0;background:var(--green);color:#04140f;cursor:pointer}
</style>

<script>
(() => {
  const SECRET = 'rainman';
  let buf = '';
  function show() {
    const root = document.getElementById('easter-root');
    if (!root) return;
    root.classList.add('easter-show');
    root.setAttribute('aria-hidden', 'false');
  }
  function hide() {
    const root = document.getElementById('easter-root');
    if (!root) return;
    root.classList.remove('easter-show');
    root.setAttribute('aria-hidden', 'true');
  }
  document.addEventListener('keydown', (e) => {
    if (!e.key) return;
    buf += e.key.toLowerCase();
    if (!SECRET.startsWith(buf)) buf = '';
    if (buf.endsWith(SECRET)) {
      show();
      startConfetti(4000);
      buf = '';
    }
  });
  document.addEventListener('click', (e) => {
    const target = e.target;
    if (!target) return;
    if (target.id === 'easter-close') hide();
    if (target.id === 'easter-root') hide();
  });
  // --- Confetti implementation ---
  function createConfettiCanvas(){
    const canvas = document.getElementById('confetti-canvas');
    if (!canvas) return null;
    const ctx = canvas.getContext('2d');
    function resize(){
      canvas.width = canvas.clientWidth * devicePixelRatio;
      canvas.height = canvas.clientHeight * devicePixelRatio;
      ctx.scale(devicePixelRatio, devicePixelRatio);
    }
    resize();
    window.addEventListener('resize', resize);
    return {canvas, ctx};
  }

  function startConfetti(duration = 3000){
    const cfg = createConfettiCanvas();
    if (!cfg) return;
    const {canvas, ctx} = cfg;
    let particles = [];
    const colors = ['#2bff9e','#ffd166','#ef476f','#06d6a0','#ffd43b','#89f7ff'];
    const gravity = 0.25;
    const drag = 0.005;
    let running = true;
    function spawn(count=40){
      for(let i=0;i<count;i++){
        const x = Math.random()*canvas.clientWidth;
        const y = -10;
        const angle = (Math.random()*Math.PI)-Math.PI/2;
        const speed = 2 + Math.random()*6;
        particles.push({x,y,vx:Math.cos(angle)*speed,vy:Math.sin(angle)*speed,rot:Math.random()*360,vr:(Math.random()-0.5)*10,w:6+Math.random()*10,color:colors[Math.floor(Math.random()*colors.length)]});
      }
    }
    let last = performance.now();
    function frame(now){
      const dt = (now-last)/16.6667; last = now;
      ctx.clearRect(0,0,canvas.width,canvas.height);
      particles.forEach((p,idx)=>{
        p.vy += gravity*dt; p.vx *= (1-drag);
        p.x += p.vx*dt; p.y += p.vy*dt; p.rot += p.vr*dt;
        ctx.save();
        ctx.translate(p.x, p.y);
        ctx.rotate(p.rot * Math.PI/180);
        ctx.fillStyle = p.color;
        ctx.fillRect(-p.w/2, -p.w/2, p.w, p.w*0.6);
        ctx.restore();
        if(p.y > canvas.clientHeight + 50) particles.splice(idx,1);
      });
      if(running) requestAnimationFrame(frame);
    }
    spawn(120);
    requestAnimationFrame(frame);
    const burst = setInterval(()=>spawn(30), 250);
    setTimeout(()=>{
      clearInterval(burst);
      running = false;
      setTimeout(()=>{ctx.clearRect(0,0,canvas.width,canvas.height);},500);
    }, duration);
  }
})();
</script>
