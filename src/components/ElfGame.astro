---
---

<section class="section" style="display: none;" id="elf-section">
  <h2 class="section-header">
    // elf_hunt.exe <span class="comment">— catch the elf</span>
  </h2>
  <div id="elf-game" class="elf-container">
    <img id="elf-image" src="/images/chris-elf.jpg" alt="Chris as an elf" class="elf-img" />
    <p class="elf-instructions">Catch the elf!</p>
  </div>
</section>

<style>
  .elf-container {
    position: relative;
    width: 100%;
    height: 300px;
    margin: 2rem 0;
    border: 1px dashed var(--green);
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.1);
    overflow: hidden;
  }
  .elf-img {
    position: absolute;
    width: 100px;
    height: auto;
    cursor: pointer;
    transition: transform 0.2s ease;
  }
  .elf-img:hover {
    transform: scale(1.1);
  }
  .elf-img.fullscreen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    object-fit: contain;
    background: #000;
    cursor: default;
  }
  .elf-instructions {
    position: absolute;
    bottom: 10px;
    left: 10px;
    color: var(--text-dim);
    font-size: 0.9rem;
    margin: 0;
  }
</style>

<script>
(() => {
  const section = document.getElementById('elf-section');
  const container = document.getElementById('elf-game');
  const img = document.getElementById('elf-image');
  if (!section || !container || !img) return;

  let clickCount = 0;
  let visible = false;

  function showGame() {
    section.style.display = 'block';
    visible = true;
    moveElf();
  }

  function moveElf() {
    if (!visible) return;
    const containerRect = container.getBoundingClientRect();
    const imgRect = img.getBoundingClientRect();
    const maxX = containerRect.width - imgRect.width;
    const maxY = containerRect.height - imgRect.height;
    const newX = Math.random() * maxX;
    const newY = Math.random() * maxY;
    img.style.left = `${newX}px`;
    img.style.top = `${newY}px`;
  }

  function handleClick() {
    if (!visible) return;
    if (img.classList.contains('fullscreen')) {
      img.classList.remove('fullscreen');
      clickCount = 0; // Reset for replay
      moveElf(); // Move back to container
      return;
    }
    clickCount++;
    if (clickCount >= 10) {
      setTimeout(() => img.classList.add('fullscreen'), 2000); // 2s delay
      return;
    }
    moveElf();
  }

  img.addEventListener('click', handleClick);
  img.addEventListener('pointerdown', handleClick);

  // Key listener for "elf"
  let buf = '';
  document.addEventListener('keydown', (e) => {
    if (!e.key) return;
    buf += e.key.toLowerCase();
    if (!'elf'.startsWith(buf)) buf = '';
    if (buf === 'elf' && !visible) {
      showGame();
      buf = '';
    }
  });

  // Initial random position (but hidden)
})();
</script>